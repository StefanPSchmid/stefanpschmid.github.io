@article{baird_bayesian_2025,
    author = {Sterling Baird  and Mehrad Ansari  and Zartashia Afzal  and Qianxiang Ai  and Alexander Al-Feghali  and Mathieu Alain  and Matias Altamirano  and Thomas Andrews  and Andy Sode Anker  and Rija Ansari  and Samuel Ampofo Appiah  and Raul Astudillo  and Ruhana Azam  and Mohammed Azzouzi  and Suneel Kumar BVS  and Ben Blaiszik  and Anna Borisova  and Andres Bran  and Pengfei Cai  and Ting-Yeh Chen  and Curtis Chong  and Samantha Corapi  and Mark Croxall  and Gbetondji Dovonon  and Jose Manuel Napoles Duarte  and Andrew Falkowski  and Giuseppe Fisicaro  and Martin Fitzner  and Quinn Gallagher  and Sabah Gaznaghi  and Jerome Genzling  and Christoph Griehl  and Ryan-Rhys Griffiths  and Taicheng Guo  and Kehan Guo  and Nipun Gupta  and Ankur Gupta  and Mohammad Haddadnia  and Yuyang Han  and Joscha Hoche  and Alexander V. Hopp  and Marko Huang  and Ayodeji Ijishakin  and Ramsey Issa  and Yeonghun Kang  and Jungtaek Kim  and Akshay Kudva  and Ruben Laplaza  and Magdalena Lederbauer  and Shi Xuan Leong  and Paul W. Leu  and Viola Muning Li  and Mingxuan Li  and Tao Liu  and Stanley Lo  and Jakub Lala  and Osman Mamun  and Owen Melville  and Michail Mitsakis  and Cameron Movassaghi  and Madhav Reddy Muthyala  and Marcel Muller  and Bozhao Nan  and Duc Nguyen  and Daniele Ongari  and Anthony Onwuli  and Can Ozkan  and Sergio Pablo-Garcia  and Elton Pan  and Ratish Panda  and Sean Park  and Jaehee Park  and Dieter Plessers  and Tobias Plotz  and Ella M. Rajaonson  and Bojana Rankovic  and Jarett Ren  and Rim Rihana  and Jurgis Ruza  and Akhil S. Nair  and Carter Salbego  and Erick Lopez Saldivar  and Arifin San  and Christina Schenk  and Stefan P. Schmid  and Dylan Schubert  and Philippe Schwaller  and Cher-Tian Ser  and Maitreyee Sharma Priyadarshini  and Yuxin Shen  and Kevin Shen  and Jiale Shi  and Farshud Sorourifar  and Adrian Sosic  and Taylor Sparks  and Jan Christopher Spies  and Felix Strieth-Kalthoff  and Suraj Sudhakar  and Aditya Sundar  and Alessio Tamburro  and Clara Tamura  and Yifeng Tang  and Dandan Tang  and Nikhil Thota  and Mohammad Erfan Toloue Sadegh Azadi  and Gary Tom  and Sang Truong  and Ricardo Valencia Albornoz  and Luis Walter  and Lawrence Wang  and Fanjin Wang  and Andrew Wang  and Yiran Wang  and Jeffrey Watchorn  and Benjamin Weiser  and Geemi Wellawatte  and Alexander Wieczorek  and Tim Wurger  and Ilya Yakavets  and Jakob Zeitler  and Sylvester Zhang  and Yimu Zhao  and Yanqiao Zhu  and Ruijie Zhu  and Yunheng Zou },
    title = {Bayesian Optimization Hackathon for Chemistry and Materials},
    journal = {ChemRxiv},
    volume = {2025},
    number = {0623},
    pages = {},
    year = {2025},
    doi = {10.26434/chemrxiv-2025-dzh5z},
    URL = {https://chemrxiv.org/doi/abs/10.26434/chemrxiv-2025-dzh5z},
    eprint = {https://chemrxiv.org/doi/pdf/10.26434/chemrxiv-2025-dzh5z},
    abstract = {The Acceleration Consortium and Merck KGaA hosted a 2-day virtual hackathon on March 27-  28, 2024, bringing together scientists to explore, collaborate, and innovate in the field of Bayesian  optimization for the physical sciences. Participants were encouraged to select or develop Bayesian  optimization algorithms, apply them to benchmarking tasks, design new benchmarks, create instructional  tutorials, and describe real-world applications. With over 100 participants across 69  academic, industry, and government organizations located in 59 cities, 19 countries, and 4 continents,  this was a global event. The outputs from this event, including developed algorithms, benchmarks,  and tutorials, will serve as valuable resources for the research community, in addition to the  new skills learned and connections formed. Released projects and general information are available  at https://ac-bo-hackathon.github.io/ and other locations linked from individual project pages.  This event demonstrates the potential of community-driven research efforts to accelerate advances  in Bayesian optimization in chemistry and materials science.}
}

