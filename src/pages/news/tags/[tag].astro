---
import Layout from '../../../layouts/Page.astro';
import Container from '../../../components/core/Container.astro';
import { newsEntries, newsTagOptions } from '../../../config/news.js';

export function getStaticPaths() {
	return newsTagOptions.map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const filteredNews = newsEntries
	.filter((item) => item.tags?.includes(tag))
	.sort((a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());

const years = [...new Set(filteredNews.map((item) => new Date(item.publishDate).getFullYear()))];

const seo = {
	title: `News #${tag}`,
	description: `News entries filtered by #${tag}.`,
};

const formatDate = (dateString) =>
	new Intl.DateTimeFormat('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).format(new Date(dateString));

const formatTags = (tags = []) => tags.map((entryTag) => `#${entryTag}`).join(', ');
---

<Layout {seo}>
	<Container>
		<section class="news-layout">
			<aside class="news-years" aria-label="News years">
				<h1>News</h1>
				<div class="news-filters">
					<p>Filter</p>
					<ul>
						<li><a href="/news">#all</a></li>
						{newsTagOptions.map((tagOption) => (
							<li>
								<a
									href={`/news/tags/${tagOption}`}
									class={tagOption === tag ? 'active' : undefined}
								>
									#{tagOption}
								</a>
							</li>
						))}
					</ul>
				</div>
				<ul>
					{years.map((year) => (
						<li>
							<a href={`#year-${year}`}>{year}</a>
						</li>
					))}
				</ul>
			</aside>

			<div class="news-content">
				{filteredNews.length === 0 && (
					<p class="news-empty">No news entries found for #{tag}.</p>
				)}

				{years.map((year) => (
					<section id={`year-${year}`} class="news-year-group">
						<h2>{year}</h2>
						<div class="news-list">
							{filteredNews
								.filter((item) => new Date(item.publishDate).getFullYear() === year)
								.map((item) => (
									<a class="news-item" href={`/news/${item.slug}`}>
										<h3>{item.title}</h3>
										<p class="news-date">
											{formatDate(item.publishDate)}{item.tags?.length > 0
												? `, ${formatTags(item.tags)}`
												: ''}
										</p>
										<p class="news-summary">{item.summary}</p>
									</a>
								))}
						</div>
					</section>
				))}
			</div>
		</section>
	</Container>
</Layout>

<style>
	.news-layout {
		margin: 3rem 0;
		display: grid;
		grid-template-columns: minmax(180px, 0.8fr) minmax(0, 2.4fr);
		gap: 2.5rem;
	}

	.news-years {
		position: sticky;
		top: 1.5rem;
		align-self: start;
	}

	.news-years h1 {
		margin-bottom: 1.25rem;
	}

	.news-filters {
		margin-bottom: 1rem;
	}

	.news-filters p {
		margin: 0 0 0.45rem;
		font-size: var(--font-size-sm);
		opacity: 0.72;
	}

	.news-filters ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.news-filters a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		text-decoration: none;
		background: var(--theme-surface-1);
		border: 1px solid color-mix(in srgb, var(--theme-on-bg) 20%, transparent);
		font-size: 0.78rem;
		color: inherit;
	}

	.news-filters a.active {
		border-color: var(--theme-primary);
	}

	.news-years ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.65rem;
	}

	.news-years a {
		color: inherit;
		text-decoration: none;
		opacity: 0.82;
	}

	.news-years a:hover {
		opacity: 1;
		text-decoration: underline;
	}

	.news-content {
		display: grid;
		gap: 2.25rem;
	}

	.news-empty {
		margin: 0;
		font-size: 0.95rem;
		opacity: 0.8;
	}

	.news-year-group {
		scroll-margin-top: 4rem;
	}

	.news-year-group h2 {
		margin-bottom: 0.75rem;
	}

	.news-list {
		display: grid;
		gap: 0.75rem;
	}

	.news-item {
		display: block;
		color: inherit;
		text-decoration: none;
		padding: 0.75rem 0;
	}

	.news-item h3 {
		margin: 0;
		font-size: 1rem;
		line-height: 1.3;
		font-weight: 600;
	}

	.news-date {
		margin: 0.22rem 0 0;
		font-size: 0.86rem;
		opacity: 0.78;
	}

	.news-summary {
		margin: 0.35rem 0 0;
		font-size: 0.9rem;
		line-height: 1.5;
		opacity: 0.9;
	}

	.news-item:hover h3 {
		text-decoration: underline;
	}

	@media (max-width: 900px) {
		.news-layout {
			grid-template-columns: 1fr;
			gap: 1.75rem;
		}

		.news-years {
			position: static;
		}

		.news-years ul {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.news-years ul {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
