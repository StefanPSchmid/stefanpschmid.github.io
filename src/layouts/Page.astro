---
import { Header, Footer } from '@components/odyssey-theme';
import Layout from './Base.astro';
import type { Props as BaseHeadProps } from '../components/head/BaseHead.astro';
import Logo from '../components/Logo.astro';
import settings from '../config/settings';
import ThemeToggle from '../components/theme-switcher/ThemeToggle.astro';
import { contactLinks } from '../config/profile.js';


export interface Props {
	seo?: BaseHeadProps;
}

import { nav } from '../config/nav.js';

const { seo } = Astro.props as Props;
---

<Layout seo={seo}>
	<Header rightMenu navData={nav} slot="header">
		<span slot="logo">
			<Logo />
		</span>
		{settings.enableThemeSwitcher && <ThemeToggle slot="action-item" />}
	</Header>
		<div id="page">
			<slot />
		</div>
		<Footer
			slot="footer"
			background="var(--theme-surface-1)"
			color="var(--theme-on-surface-1)"
			navLinks={nav}
			socials={contactLinks}
		>
			<Logo slot="logo" />
		</Footer>
	</Layout>
