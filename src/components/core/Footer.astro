---
import Container  from '../core/Container.astro';
import SocialIcon from '../SocialIcon.astro';

const { socials = [], navLinks = [], background, color } =
  Astro.props;
---

<footer
  style={background && `--footer-bg:${background}; --footer-color:${color}`}
>
  <Container>
    <div class="footer-grid">
      <div class="footer-left">
        <a href="/" class="footer-name">
          <slot name="logo" />
        </a>
        <ul class="footer-socials">
          {socials.map((social) => (
            <li>
              <a
                href={social.url}
                target={social.newTab ? '_blank' : undefined}
                rel={social.newTab ? 'noopener noreferrer' : undefined}
                title={social.name}
                aria-label={social.name}
              >
                <SocialIcon name={social.icon} />
              </a>
            </li>
          ))}
        </ul>
      </div>
      <nav class="footer-right" aria-label="Footer navigation">
        <ul class="footer-nav">
          {navLinks.map((item) => (
            <li>
              <a href={item.slug}>{item.title}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </Container>
</footer>

<style>
  footer {
    --footer-bg: var(--theme-primary);
    --footer-color: var(--theme-on-primary);
    background-color: var(--footer-bg);
    color: var(--footer-color);
    margin-top: 4rem;
    padding: 2.5rem 0;
  }
  .footer-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 2fr 1fr;
  }
  .footer-name {
    color: inherit;
    display: inline-block;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .footer-name:hover {
    text-decoration: underline;
  }
  .footer-socials,
  .footer-nav {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer-nav li {
    margin-bottom: 0.5rem;
  }
  .footer-socials a,
  .footer-nav a {
    color: inherit;
    text-decoration: none;
  }
  .footer-socials a {
    height: 2.4rem;
    width: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--theme-surface-1) 85%, transparent);
    border: 1px solid color-mix(in srgb, var(--theme-on-bg) 30%, transparent);
  }
  .footer-socials a:hover,
  .footer-nav a:hover {
    text-decoration: underline;
  }
  .footer-socials a:hover {
    text-decoration: none;
    border-color: var(--theme-primary);
  }
  .footer-right {
    justify-self: end;
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-right {
      justify-self: start;
    }
  }
</style>
